{
  "expo": {
    "name": "Alchemize",
    "slug": "alchemize-repo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c0520"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.alchemize-level-up",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Alchemize uses your photo library to let you set a profile photo and add images to your manifestation board.",
        "NSCameraUsageDescription": "Alchemize uses your camera to take profile photos and scan food for calorie tracking.",
        "NSMicrophoneUsageDescription": "Alchemize uses the microphone for audio recording features.",
        "NSHealthShareUsageDescription": "Alchemize reads your workout and activity data from Apple Health to enhance your fitness tracking experience.",
        "NSCalendarsUsageDescription": "Alchemize syncs your appointments to your iPhone calendar so you never miss an important event.",
        "NSCalendarsFullAccessUsageDescription": "Alchemize syncs your appointments to your iPhone calendar so you never miss an important event."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0c0520"
      },
      "package": "app.rork.alchemize_app_skeleton",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "privacy": "https://alchemize.app/privacy",
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true,
          "android": {
            "enableFTS": false,
            "useSQLCipher": false
          },
          "ios": {
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}